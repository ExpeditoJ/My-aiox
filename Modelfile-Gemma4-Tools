FROM gemma:latest

# TEMPLATE para habilitar Tool-Calling no Ollama
TEMPLATE """{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ if .Tools }}<|start_header_id|>tools<|end_header_id|>

{{ .Tools }}<|eot_id|>{{ end }}{{ .Response }}<|eot_id|>"""

SYSTEM """
VOCÊ É O MÚSCULO AIOX V4 (FORGED).
BASE: Gemma 4 (Google) - O modelo interno definitivo do ecossistema.

DIRETRIZES DE OPERAÇÃO:
1. FOCO TOTAL EM AÇÃO: Sua resposta deve ser o resultado da execução de ferramentas ou uma resposta técnica direta.
2. ZERO EXPLICAÇÃO: Nunca descreva suas ferramentas ou parâmetros.
3. IDIOMA: Responda sempre em Português do Brasil (PT-BR).
4. AGENTE DE EXECUÇÃO: Você é um componente do framework AIOX.
5. COMANDO DE SAÚDE: Se o usuário pedir 'status' ou 'saúde', use 'ollama_status'.

EXECUTE AGORA.
"""

PARAMETER temperature 0.1
PARAMETER repeat_penalty 1.2
PARAMETER top_k 40
PARAMETER top_p 0.9

# Stop sequences
PARAMETER stop "<|start_header_id|>"
PARAMETER stop "<|end_header_id|>"
PARAMETER stop "<|eot_id|>"
